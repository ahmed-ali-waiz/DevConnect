PORT=5000
# MongoDB Atlas (example format). Put the real password/user in your deployment env vars.
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/devconnect?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://DevConnect:wattoo2004=@cluster0.a38aagp.mongodb.net/
NODE_ENV=development

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5000

# Email (Mailtrap sandbox — check inbox at mailtrap.io)
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USER=your_email_user
EMAIL_PASS=your_email_pass
EMAIL_FROM=DevConnect <noreply@devconnect.dev>

# OAuth - Get credentials from Google Cloud Console & GitHub Developer Settings
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
